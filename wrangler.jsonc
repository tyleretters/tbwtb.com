{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tbwtb-com",
  "compatibility_date": "2026-05-14",
  "assets": {
    "directory": "./",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "observability": {
    "enabled": true
  },
  "workers_dev": true,
  "routes": [
    {
      "pattern": "tbwtb.com/*",
      "zone_name": "tbwtb.com"
    }
  ]
}
